# ─── MOUSSEFER — Variables d'environnement requises ──────────────────────────
# Copier ce fichier en .env et remplir TOUTES les valeurs avant docker-compose up
# Ne jamais committer le fichier .env dans git

# ─── JWT ─────────────────────────────────────────────────────────────────────
# Minimum 256 bits (32 caractères) — générer avec: openssl rand -base64 32
JWT_SECRET=CHANGE_ME_AT_LEAST_32_CHARS_LONG_SECRET_KEY

# ─── Communication inter-services ────────────────────────────────────────────
# Générer avec: openssl rand -hex 32
INTERNAL_API_KEY=CHANGE_ME_INTERNAL_SECRET

# ─── Stripe ──────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_CHANGE_ME
STRIPE_WEBHOOK_SECRET=whsec_CHANGE_ME

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_PASSWORD=CHANGE_ME_REDIS_PASS

# ─── MinIO ───────────────────────────────────────────────────────────────────
MINIO_ROOT_USER=CHANGE_ME_MINIO_USER
MINIO_ROOT_PASSWORD=CHANGE_ME_MINIO_PASS

# ─── MySQL (root) ────────────────────────────────────────────────────────────
MYSQL_ROOT_PASSWORD=CHANGE_ME_ROOT_PASS

# ─── MySQL (par service) ─────────────────────────────────────────────────────
AUTH_DB_PASSWORD=CHANGE_ME
USER_DB_PASSWORD=CHANGE_ME
TRAJET_DB_PASSWORD=CHANGE_ME
RESA_DB_PASSWORD=CHANGE_ME
PAY_DB_PASSWORD=CHANGE_ME
NOTIF_DB_PASSWORD=CHANGE_ME
CHAT_DB_PASSWORD=CHANGE_ME
VOYAGE_DB_PASSWORD=CHANGE_ME
DEMANDE_DB_PASSWORD=CHANGE_ME
AVIS_DB_PASSWORD=CHANGE_ME

# ─── Swagger (true en dev, false en prod) ────────────────────────────────────
SWAGGER_ENABLED=true

# ─── CORS (frontend URL) ─────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:4200
